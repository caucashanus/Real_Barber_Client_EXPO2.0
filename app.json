{
  "expo": {
    "name": "Real Barber",
    "slug": "realbarber",
    "version": "1.0.13",
    "runtimeVersion": "1.0.13",
    "scheme": "realbarber",
    "experiments": {
      "tsconfigPaths": true
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikace potřebuje přístup ke galerii pro výběr profilové fotky.",
          "cameraPermission": "Aplikace potřebuje přístup ke fotoaparátu pro profilovou fotku."
        }
      ],
      "@bacons/apple-targets",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-image",
      "expo-sharing",
      "expo-video",
      [
        "expo-calendar",
        {
          "calendarPermission": "Aplikace může přidat termín do vašeho kalendáře.",
          "remindersPermission": "Aplikace může přidat připomínku k termínu."
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "deploymentTarget": "16.2",
      "appleTeamId": "VK8YT9654D",
      "bundleIdentifier": "com.realbarber.client",
      "buildNumber": "50",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsUsageDescription": "Aplikace může přidat termín do vašeho kalendáře.",
        "NSCalendarsFullAccessUsageDescription": "Aplikace může přidat termín do vašeho kalendáře.",
        "NSRemindersUsageDescription": "Aplikace může přidat připomínku k termínu.",
        "NSRemindersFullAccessUsageDescription": "Aplikace může přidat připomínku k termínu."
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.realbarber.client"
        ]
      }
    },
    "android": {
      "package": "com.realbarber.client",
      "versionCode": 50,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "344f73c8-de32-4770-8c07-62154df9af0c"
      }
    }
  }
}
