{
  "expo": {
    "name": "Real Barber",
    "slug": "realbarber",
    "version": "1.0.1",
    "runtimeVersion": "1.0.0",
    "scheme": "realbarber",
    "experiments": {
      "tsconfigPaths": true
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikace potřebuje přístup ke galerii pro výběr profilové fotky.",
          "cameraPermission": "Aplikace potřebuje přístup ke fotoaparátu pro profilovou fotku."
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.realbarber.client.ExpoWidgetsTarget",
          "groupIdentifier": "group.com.realbarber.client",
          "enablePushNotifications": true,
          "widgets": [
            {
              "name": "RealBarberWidget",
              "displayName": "Real Barber",
              "description": "Rychlý přehled v aplikaci Real Barber",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryRectangular"
              ]
            },
            {
              "name": "RealBarberLiveActivity",
              "displayName": "Real Barber Aktivita",
              "description": "Live Activity pro Real Barber",
              "supportedFamilies": [
                "systemSmall"
              ]
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-image",
      "expo-sharing",
      "expo-video"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.realbarber.client",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.realbarber.client",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "344f73c8-de32-4770-8c07-62154df9af0c"
      }
    }
  }
}
